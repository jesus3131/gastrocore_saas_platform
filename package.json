{
  "name": "gastrocore",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GastroCore - All-in-one Restaurant Management SaaS Platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json,prisma}\"",
    "db:generate": "pnpm --filter @gastrocore/backend run db:generate",
    "db:push": "pnpm --filter @gastrocore/backend run db:push",
    "db:migrate": "pnpm --filter @gastrocore/backend run db:migrate",
    "db:seed": "pnpm --filter @gastrocore/backend run db:seed",
    "docker:dev": "docker-compose -f infrastructure/docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f infrastructure/docker/docker-compose.prod.yml up",
    "clean": "turbo clean && rimraf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@prisma/client": "^6.1.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.4.0",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0"
  }
}
