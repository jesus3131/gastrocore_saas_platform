# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://gastrocore:gastrocore@localhost:5432/gastrocore?schema=public"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ─── Tenant ──────────────────────────────────────────────────
DEFAULT_TENANT_PLAN="basic"

# ─── Storage ─────────────────────────────────────────────────
STORAGE_PROVIDER="s3"
STORAGE_BUCKET="gastrocore-assets"
STORAGE_REGION="us-east-1"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# ─── Email ───────────────────────────────────────────────────
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@gastrocore.com"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Integrations ────────────────────────────────────────────
RAPPI_API_KEY=""
UBER_EATS_API_KEY=""
DIDI_FOOD_API_KEY=""
MERCADO_PAGO_ACCESS_TOKEN=""

# ─── Feature Flags ──────────────────────────────────────────
FEATURE_KDS_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_ONLINE_ORDERING_ENABLED=true

# ─── Analytics ──────────────────────────────────────────────
PYTHON_ANALYTICS_URL="http://localhost:8000"

# ─── App ─────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:5173"
LOG_LEVEL="debug"
